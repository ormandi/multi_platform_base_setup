# C++20 for all user code. Do NOT add --host_cxxopt (would force C++20 on
# exec-config tooling) and do NOT set --dynamic_mode=off (breaks libstdc++).
build --cxxopt=-std=c++20

# Target-platform shortcuts. Pick one on the command line to cross-compile, e.g.
#   bazel build --config=linux_x86_64_libcxx //src/benchmark:benchmark
build:macos_arm64_libcxx --platforms=//platforms:macos_arm64_libcxx
build:macos_x86_64_libcxx --platforms=//platforms:macos_x86_64_libcxx
build:linux_arm64_libcxx --platforms=//platforms:linux_arm64_libcxx
build:linux_arm64_stdcxx --platforms=//platforms:linux_arm64_stdcxx
build:linux_x86_64_libcxx --platforms=//platforms:linux_x86_64_libcxx
build:linux_x86_64_stdcxx --platforms=//platforms:linux_x86_64_stdcxx

# Enable the manylinux configuration (forces stdc++ for manylinux targets).
build:manylinux --//:manylinux_compatible=True
